# ============================================================
# License Plate Recognition — .gitignore
# ============================================================

# ------ Python ------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo

# ------ Virtual environments ------
.venv/
venv/
env/
ENV/
.conda/

# ------ Jupyter / IPython ------
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# Large / Legacy Notebooks (30MB+ each)
notebooks/Deployment*.ipynb
notebooks/License*.ipynb

# ===== LARGE MODEL WEIGHTS (never push to GitHub) =====
# YOLO .pt weight files are 57+ MB — use Git LFS or share via Kaggle/HuggingFace
*.pt
*.pth
*.onnx
*.tflite
*.engine
*.torchscript

# ------ Document files (use only README.md) ------
*.doc
*.docx
*.pdf
*.xls
*.xlsx
*.pptx

# ------ Plain-text scratch files (not project docs) ------
# Keep requirements.txt — exclude ad-hoc notes
archive/readme.txt
archive/reorganization_report.txt

# ===== ARCHIVE FOLDER (legacy / duplicate work) =====
archive/

# ===== LARGE DATASET IMAGES (433 source images) =====
# The raw Cars*.png dataset belongs on Kaggle, not in the repo
# Reference: https://www.kaggle.com/datasets/fareselmenshawii/large-license-plate-dataset
archive/images/

# ===== OUTPUT / GENERATED FILES =====
# Keep curated showcase images (referenced in README) but exclude bulk outputs
Output/videos/
Output/metrics/
Output/visualizations/

# Detection outputs — keep only the curated ones used in README
Output/detections/Screenshot*
Output/detections/plate_captures (*).png
# Output/detections/result_Cars*.png  # Uncomment to ignore all result images

# ------ General large binary / media ------
*.mp4
*.avi
*.mov
*.mkv
*.gif
*.zip
*.tar.gz
*.rar
*.7z

# ------ YOLO training run artifacts ------
runs/
yolo_output/
train/
exp/
weights/

# ------ Miscellaneous OS / IDE ------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ------ Secrets / API keys ------
.env
.env.*
secrets.yaml
config.local.*

# ------ Logs / temp ------
*.log
*.tmp
*.bak
tmp/
temp/
